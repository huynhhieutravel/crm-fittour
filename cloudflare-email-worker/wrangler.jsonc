{
  "name": "fittour-email",
  "main": "./src/index.ts",
  "compatibility_date": "2024-05-12",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "DOMAINS": "fittour.vn",
    "CRM_WEBHOOK_URL": "https://erp.fittour.vn/api/emails/incoming"
  },
  "send_email": [
    { "name": "EMAIL" }
  ],
  "r2_buckets": [
    { "binding": "BUCKET", "bucket_name": "fittour-email-attachments" }
  ]
}
